# LLM provider for local playbook + tools (ignored when OPENAI_PROMPT_ID uses OpenAI Responses only).
# openai | groq | ollama — if unset: uses OpenAI when OPENAI_API_KEY is set, else Groq when GROQ_API_KEY, else Ollama.
AI_PROVIDER=

# Agent orchestrator: intent classification + KB section retrieval before each reply (extra LLM call). Set "false" to skip.
ORCHESTRATOR_ENABLED=true

# Workflow engine: funnel stages, auto draft leads, conversation summaries, strict KB policy. Set "false" to use orchestrator only.
WORKFLOW_ENGINE_ENABLED=true

# Next.js dev: set to 1 if webpack cache errors (ENOENT *.pack.gz under .next/cache). Slower HMR; prefer stopping dev and deleting .next first.
DISABLE_WEBPACK_DEV_CACHE=

# OpenAI (default when OPENAI_API_KEY is set)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Groq (https://console.groq.com/keys) — fast inference, set AI_PROVIDER=groq or only GROQ_API_KEY (no OpenAI key)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama — local models; install from https://ollama.com then: ollama serve ; ollama pull llama3.2
OLLAMA_BASE_URL=http://127.0.0.1:11434/api
OLLAMA_MODEL=llama3.2

# Workspace gate (optional). When set, /agent requires sign-in at /login with this access code.
# Leave empty for open access during local development.
DIGISALES_ACCESS_PASSWORD=

# --- AI Sales Agent Platform (dashboard at /dashboard) ---
# Supabase: create project at https://supabase.com — run supabase/migrations/001_platform_schema.sql
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Or Supabase dashboard "publishable" key (same role as anon for client auth)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only — never expose to client (required for public embed/live chat)
SUPABASE_SERVICE_ROLE_KEY=
# Default platform agent for /embed, /agent, and sidebar "Open live agent"
NEXT_PUBLIC_PLATFORM_AGENT_ID=
PLATFORM_AGENT_ID=

# Demo mode (when Supabase vars are empty): login at /auth/login
PLATFORM_DEMO_EMAIL=admin@digitalreadyghana.com
PLATFORM_DEMO_PASSWORD=demo1234

# Demo room Stage 2: AI workflow ON by default (agent + KB + assets + scoring + booking/handoff).
# Set DEMO_ROOM_STAGE1_PLACEHOLDER=true to use placeholder chat only (no LLM).
# Set DEMO_ROOM_AI_ENABLED=false to disable AI explicitly.
DEMO_ROOM_STAGE1_PLACEHOLDER=
DEMO_ROOM_AI_ENABLED=

# Google OAuth — enable Google provider in Supabase Dashboard → Authentication → Providers
# Add redirect URLs (Authentication → URL configuration):
#   http://localhost:3000/auth/callback
#   http://localhost:3000/auth/reset-password
#   https://your-domain.com/auth/callback
#   https://your-domain.com/auth/reset-password

# reCAPTCHA v3 (invisible) — https://www.google.com/recaptcha/admin (choose v3)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Enforce on login/register (default: true in production when keys are set)
RECAPTCHA_ENFORCE=
RECAPTCHA_MIN_SCORE=0.5

# OpenAI Dashboard → Prompts (https://platform.openai.com/prompts)
# When set, chat answers use your hosted prompt (pmpt_…) instead of only local files
OPENAI_PROMPT_ID=
OPENAI_PROMPT_VERSION=1
# Set to false to use ONLY the OpenAI prompt (no company-knowledge.md merge)
OPENAI_PROMPT_MERGE_LOCAL_KB=true
# Optional: force a model on the Responses API (otherwise the hosted prompt's model is used).
OPENAI_RESPONSES_MODEL=
# Set to true to also pass OPENAI_MODEL to Responses API (usually leave unset for hosted prompts).
OPENAI_PROMPT_INCLUDE_MODEL=

# Brand (shown in greetings and prompts)
NEXT_PUBLIC_COMPANY_NAME=Digital Ready Ghana
NEXT_PUBLIC_COMPANY_TAGLINE=Digital marketing, branding & business growth
NEXT_PUBLIC_ASSISTANT_NAME=Digital Ready Assistant

# Booking
NEXT_PUBLIC_BOOKING_URL=https://calendly.com/your-team/consultation
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
CALENDLY_ACCESS_TOKEN=
CALENDLY_WEBHOOK_SIGNING_KEY=

# Human escalation
ESCALATION_EMAIL=team@digitalreadyghana.com
ESCALATION_SLACK_WEBHOOK=
ESCALATION_EMAIL_WEBHOOK=

# CRM — local database files in ./data/ (leads.json, crm-leads.json) + optional webhook
CRM_WEBHOOK_URL=
HUBSPOT_ACCESS_TOKEN=

# Follow-up automation
FOLLOWUP_WEBHOOK_URL=

# Campaign scheduler cron (Vercel: set CRON_SECRET in project env; vercel.json hits /api/cron/campaigns every 10 min)
CRON_SECRET=

# Campaign outbound (dashboard → Run campaign)
RESEND_API_KEY=
CAMPAIGN_EMAIL_FROM=Digital Ready Ghana <team@digitalreadyghana.com>
CAMPAIGN_EMAIL_REPLY_TO=
# Fallback if Resend is not set (same shape as escalation webhook)
CAMPAIGN_EMAIL_WEBHOOK=

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Meta App Secret — used to verify X-Hub-Signature-256 on webhooks
WHATSAPP_APP_SECRET=

# Twilio Voice
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Public base URL Twilio calls (must match Voice webhook URL exactly). Example: https://your-domain.com
# Dev: use ngrok URL + path. If unset, signature validation uses x-forwarded-* from the request.
TWILIO_WEBHOOK_PUBLIC_URL=
# Media stream WebSocket (dev: run npm run voice:ws, default port 3099)
VOICE_MEDIA_WS_PORT=3099
VOICE_MEDIA_WS_PUBLIC_URL=
VOICE_MEDIA_WS_URL=

# --- Real-time demo room (Stage 3) ---
# AI workflow for /demo-room (set true only for offline placeholder chat)
# DEMO_ROOM_STAGE1_PLACEHOLDER=false
# DEMO_ROOM_AI_ENABLED=true
# OpenAI — voice TTS for demo room (server-side only)
# OPENAI_API_KEY=sk-...
# LiveKit — short-lived room tokens from /api/demo/sessions/[id]/token (never expose secret to client)
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_URL=wss://your-project.livekit.cloud
# Public app URL for admin join links and Tavus webhook callbacks
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Tavus CVI — talking video avatar (server-side only; never expose API key to client)
# TAVUS_API_KEY=
# TAVUS_DEFAULT_REPLICA_ID=
# TAVUS_DEFAULT_PERSONA_ID=
# D-ID Agents (server-side only — never expose DID_API_KEY to the browser)
# DID_API_KEY=
# DID_DEFAULT_AGENT_ID=
# DID_DEFAULT_VOICE_ID=
# DID_ALLOWED_DOMAINS=localhost,127.0.0.1
# NEXT_PUBLIC_APP_URL=https://your-app.example.com

# Video avatar iframe (legacy optional embed; Tavus uses conversation_url from API)
NEXT_PUBLIC_AVATAR_EMBED_URL=

# Meetings hub (/meet)
NEXT_PUBLIC_ZOOM_SCHEDULING_URL=
# Daily / Jitsi / Whereby embed URL for in-browser video
NEXT_PUBLIC_BROWSER_CALL_EMBED_URL=

# Admin APIs
ADMIN_API_SECRET=

# Billing — Paystack (trial then pay for full workspace access)
# Set BILLING_ENFORCEMENT=true in production to gate dashboard after trial
BILLING_ENFORCEMENT=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_CURRENCY=GHS

HUMAN_SUPPORT_HOURS=Monday–Friday, 9:00 AM – 6:00 PM GMT
